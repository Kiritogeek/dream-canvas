{
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(**)",
      "Grep(**)",
      "Skill(*)",
      "Agent(*)",
      "mcp__*__*"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push * main)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/scripts/perf-audit.sh\""
          }
        ]
      }
    ],
    "SessionEnd": []
  }
}
