# Copier ce fichier vers .env et renseigner les valeurs (ne pas commiter .env).

# Référence projet (optionnel, selon les scripts / doc)
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# URL du projet Supabase (Settings → API)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Clé anon / publishable uniquement — jamais la service_role
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# Optionnel : réserve le lien admin Stripe / plan (voir Plans.tsx)
# VITE_ADMIN_EMAIL=""
