{
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "WebFetch(*)",
      "WebSearch",
      "Read(*)",
      "Glob(**)",
      "Grep(**)",
      "Skill(*)"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push * main)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/scripts/perf-audit.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/c/Users/marin/.claude/skills/wiki-brain/hooks/session-end.sh\""
          }
        ]
      }
    ]
  }
}
